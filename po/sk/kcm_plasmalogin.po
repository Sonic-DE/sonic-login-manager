#: kcm.cpp:78
msgid ""
"Unable to save settings because a temporary directory could not be created."
msgstr ""
"Nie je možné uložiť nastavenia, pretože sa nepodarilo vytvoriť dočasný "
"adresár."

#: kcm.cpp:139
msgid "Unable to save settings because the config could not be opened."
msgstr ""
"Nie je možné uložiť nastavenia, pretože sa nepodarilo otvoriť konfiguráciu."

#: kcm.cpp:214
msgid ""
"Unable to synchronise Plasma settings because the 'plasmalogin' user does "
"not exist. Please check your Plasma Login install."
msgstr ""
"Nie je možné synchronizovať nastavenia Plasma, pretože používateľ "
"'plasmalogin' neexistuje. Skontrolujte inštaláciu Plasma Login."

#: kcm.cpp:267
msgid ""
"Unable to reset Plasma settings because the 'plasmalogin' user does not "
"exist. Please check your Plasma Login install."
msgstr ""
"Nie je možné obnoviť nastavenia Plasma, pretože používateľ 'plasmalogin' "
"neexistuje. Skontrolujte inštaláciu Plasma Login."

