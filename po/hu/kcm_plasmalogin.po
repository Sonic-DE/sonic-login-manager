"módosításai tükröződnek:"

#: ui/main.qml:66
#, kde-kuit-format
msgctxt "@info"
msgid ""
"<para><list><item>Color scheme</item><item>Cursor theme and size</"
"item><item>Font and font rendering</item><item>NumLock preference</"
"item><item>Plasma theme</item><item>Scaling DPI</item><item>Screen "
"configuration</item><item>Keyboard layouts</item></list></para>"
msgstr ""
"<para><list><item>Színséma</item><item>Kurzortéma és -méret</"
"item><item>Betűkészlet és -renderelés</item><item>NumLock beállítások</"
"item><item>Plasma téma</item><item>DPI skálázás</"
"item><item>Képernyőbeállítás</item><item>Billentyűzetkiosztás</item></list></"
"para>"

#: ui/main.qml:67
#, kde-format
msgid ""
"Please note that theme files must be installed globally to be reflected on "
"the Plasma login screen."
msgstr ""
"Fontos, hogy a témákat globálisan kell telepíteni, hogy a Plasma "
"bejelentkező képernyőn tükröződjenek."

