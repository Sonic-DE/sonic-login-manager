#: kcm.cpp:78
msgid ""
"Unable to save settings because a temporary directory could not be created."
msgstr "Nelze uložit nastavení protože nelze vytvořit dočasný adresář."

#: kcm.cpp:132
msgid "Unable to save settings because the config could not be opened."
msgstr "Nelze uložit nastavení protože nastavení nelze načíst."

#: kcm.cpp:204
msgid ""
"Unable to synchronise Plasma settings because the 'plasmalogin' user does "
"not exist. Please check your Plasma Login install."
msgstr ""
"Nelze synchronizovat nastavení Plasma, protože uživatel 'plasmalogin' "
"neexistuje. Prosím, prověřte svou instalaci Plasma Login."

#: kcm.cpp:255
msgid ""
"Unable to reset Plasma settings because the 'plasmalogin' user does not "
"exist. Please check your Plasma Login install."
msgstr ""
"Nelze pokračovat. Uživatel 'sddm' neexistuje. Prosím, prověřte svou "
"instalaci Plasma Login."

