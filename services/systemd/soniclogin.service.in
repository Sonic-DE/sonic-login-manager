[Unit]
Description=Sonic Login Manager
Documentation=man:soniclogin(1) man:soniclogin.conf(5)
Conflicts=getty@tty${SONICLOGIN_INITIAL_VT}.service
After=systemd-user-sessions.service getty@tty${SONICLOGIN_INITIAL_VT}.service plymouth-quit.service systemd-logind.service
PartOf=graphical.target
StartLimitIntervalSec=30
StartLimitBurst=2

[Service]
ExecStartPre=-udevadm settle --timeout=10
ExecStart=@CMAKE_INSTALL_FULL_BINDIR@/soniclogin
Restart=always

[Install]
Alias=display-manager.service

