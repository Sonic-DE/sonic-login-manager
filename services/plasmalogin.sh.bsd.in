#!/bin/sh
# PROVIDE: plasmalogin
# REQUIRE: LOGIN dbus syslogd
# BEFORE: getty
# KEYWORD: shutdown

. /etc/rc.subr

name="plasmalogin"
rcvar="plasmalogin_enable"
pidfile="/var/run/${name}.pid"
command="@CMAKE_INSTALL_FULL_BINDIR@/plasmalogin"
command_args=""

load_rc_config $name
: ${plasmalogin_enable:=NO}

start_cmd="${name}_start"
sig_stop="TERM"
sig_reload="USR1"

plasmalogin_start()
{
    /usr/sbin/daemon -f -p "${pidfile}" "${command}" ${command_args}
}

run_rc_command "$1"
