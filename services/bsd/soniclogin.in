#!/bin/sh
# PROVIDE: soniclogin
# REQUIRE: LOGIN dbus syslogd
# BEFORE: getty
# KEYWORD: shutdown

. /etc/rc.subr

name="soniclogin"
rcvar="soniclogin_enable"
pidfile="/var/run/${name}.pid"
command="@CMAKE_INSTALL_FULL_BINDIR@/soniclogin"
command_args=""

load_rc_config $name
: ${soniclogin_enable:=NO}

start_cmd="${name}_start"
sig_stop="TERM"
sig_reload="USR1"

soniclogin_start()
{
    /usr/sbin/daemon -f -p "${pidfile}" "${command}" ${command_args}
}

run_rc_command "$1"
