#
# s6 service finish script for Sonic Login Manager
# Install as /etc/s6/sv/plasmalogin/finish

# This script is called when the daemon exits
# Clean up auth sockets
rm -f /tmp/plasmalogin-auth*
rm -f /tmp/xauth_*

# Exit 0 to not restart, exit 1 to restart
# For a display manager, we typically want to restart on failure
exit 1
