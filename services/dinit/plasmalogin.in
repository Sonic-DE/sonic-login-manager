# dinit service file for Sonic Login Manager
# Install as /etc/dinit.d/plasmalogin

type = process
command = @CMAKE_INSTALL_FULL_BINDIR@/plasmalogin
restart = true
working-dir = /
run-as = root

# Wait for these core services if they exist on the system
waits-for: dbus
waits-for: elogind
