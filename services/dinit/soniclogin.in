# dinit service file for Sonic Login Manager
# Install as /etc/dinit.d/soniclogin

type = process
command = @CMAKE_INSTALL_FULL_BINDIR@/soniclogin
smooth-recovery = true
logfile         = /var/log/sonic/loginmanager.log
depends-on      = logind
depends-on      = login.target
