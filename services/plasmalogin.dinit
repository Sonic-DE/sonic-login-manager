# dinit service file for Sonic Login Manager
# Runs setup inline, then starts plasmalogin-main.
# Install as /etc/dinit.d/plasmalogin

type = scripted
command = sh -c '@CMAKE_INSTALL_FULL_LIBEXECDIR@/plasmalogin-setup && dinitctl start plasmalogin-main'
log-type = buffer

# Wait for these core services if they exist on the system
waits-for: dbus
waits-for: elogind
