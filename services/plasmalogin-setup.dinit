# dinit service file for Sonic Login Manager setup
# Install as /etc/dinit.d/plasmalogin-setup

type = scripted
command = @CMAKE_INSTALL_FULL_LIBEXECDIR@/plasmalogin-setup
log-type = buffer
restart = false
