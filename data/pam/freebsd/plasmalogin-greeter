# FreeBSD PAM configuration for plasmalogin greeter

# Auth: Often inherited from system, but 'permit' is common for just starting the UI
auth        required    pam_permit.so

# Account: We check nologin to see if we should even show a login screen
account     required    pam_nologin.so
account     required    pam_unix.so

# Session: Usually minimal for the greeter
session     required    pam_permit.so